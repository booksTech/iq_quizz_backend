# Server Configuration
# Same env values are used for local, alpha, prod, and all environments.
PORT=3000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=supersecretkey_change_me
JWT_EXPIRE=7d

# Encryption Configuration
ENCRYPTION_KEY=8f4d2a91c7b64e5fa3d8c1b2e7f9a6c4
IV_KEY=5d8f1a7c9b3e4d2f
# Optional: base64 encoded RSA private key for stable client-side password encryption.
# If omitted, a temporary key pair is generated on backend startup.
PASSWORD_ENCRYPTION_PRIVATE_KEY_BASE64=

# Database Configuration
MONGODB_URI=mongodb://127.0.0.1:27017/iq-quizz-v1

# CORS Configuration
# Allow all origins for now. Change this later as needed.
CORS_ORIGIN=*
